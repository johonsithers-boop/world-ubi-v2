# ===========================================
# Base UBI - Production Environment
# ===========================================

# -----------------------------------------
# Authentication
# -----------------------------------------
NEXTAUTH_URL=https://your-domain.com
# Generate with: openssl rand -hex 64
NEXTAUTH_SECRET=replace_with_128_hex_chars_or_equivalent_entropy

# -----------------------------------------
# Blockchain
# -----------------------------------------
NEXT_PUBLIC_CHAIN=mainnet
NEXT_PUBLIC_BASIC_INCOME_CONTRACT=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_STAKING_CONTRACT=0x0000000000000000000000000000000000000000

# -----------------------------------------
# Data storage
# -----------------------------------------
# Vercel serverless writeable path (ephemeral per instance).
# For durable storage use an external DB.
DATABASE_PATH=/tmp/votes.db

# -----------------------------------------
# Optional: Distributed rate limiting (Upstash)
# Set both values together to enable Redis-backed rate limits.
# -----------------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace_with_upstash_rest_token
